<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_camera">

    <!-- ── Camera feed ── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── AR Overlay (Kaaba marker, sweep arrows, edge glow) ── -->
    <com.hashashino.qiblaar.views.ArOverlayView
        android:id="@+id/ar_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Header bar ── -->
    <LinearLayout
        android:id="@+id/ll_ar_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <!-- Mode chip: "AR · live" or "AR · pre-set" -->
        <TextView
            android:id="@+id/tv_mode_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="AR · live"
            android:textColor="@color/text_3"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            android:background="@drawable/bg_chip_neutral" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Status chip: ALIGNED / X° OFF / WRONG POSE / COMPASS DISTURBED -->
        <TextView
            android:id="@+id/tv_status_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            android:background="@drawable/bg_chip_neutral"
            android:text="…" />

        <!-- Camera toggle button -->
        <ImageView
            android:id="@+id/btn_toggle_camera"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:padding="8dp"
            android:src="@drawable/ic_camera"
            android:tint="@color/text_3"
            android:background="@drawable/bg_chip_neutral"
            android:contentDescription="Toggle camera"
            android:clickable="true"
            android:focusable="true" />

        <!-- Calibrate icon button -->
        <ImageView
            android:id="@+id/btn_calibrate_header"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:padding="8dp"
            android:src="@drawable/ic_rotate_ccw"
            android:tint="@color/text_3"
            android:background="@drawable/bg_chip_neutral"
            android:contentDescription="@string/recalibrate_now"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- ── Pose hint overlay (shown when !isPoseValid) ── -->
    <FrameLayout
        android:id="@+id/fl_pose_hint"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0B0D1C"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="72dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <com.hashashino.qiblaar.views.PhoneOrientationHintView
                android:id="@+id/phone_tilt_hint_ar"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                app:orientationMode="upright" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/pose_hint_upright_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/pose_hint_upright_body"
                android:textColor="@color/text_2"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5"
                android:gravity="center" />

            <!-- Live tilt chip -->
            <TextView
                android:id="@+id/tv_tilt_chip_ar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:textColor="@color/amber_text"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_card_amber"
                android:text="Currently tilted 0° — needs near vertical" />

            <!-- Use compass mode instead -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_use_compass_mode"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="20dp"
                android:text="@string/pose_hint_use_compass"
                style="@style/Widget.QiblaAR.Button.Quiet" />

        </LinearLayout>
    </FrameLayout>

    <!-- ── Interference card (shown when SEVERE && !isLocked) ── -->
    <FrameLayout
        android:id="@+id/fl_interference"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="80dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="@drawable/bg_card_red">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_magnet"
                    android:tint="@color/red_text"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/ar_marker_drifting"
                    android:textColor="@color/red_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_interference_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_2"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5" />

            <!-- Tip row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="top"
                android:padding="10dp"
                android:background="@drawable/bg_card_neutral">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginTop="1dp"
                    android:src="@drawable/ic_lock"
                    android:tint="@color/green"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/ar_interference_tip"
                    android:textColor="@color/text_3"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.45" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_switch_preset"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="14dp"
                android:text="@string/switch_to_preset"
                style="@style/Widget.QiblaAR.Button"
                app:icon="@drawable/ic_lock"
                app:iconSize="16dp" />

        </LinearLayout>
    </FrameLayout>

    <!-- ── Aligned bottom bar (shown when ALIGNED) ── -->
    <LinearLayout
        android:id="@+id/ll_aligned_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="90dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/bg_card_green"
        android:visibility="gone">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check"
            android:tint="@color/green"
            android:importantForAccessibility="no" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pointing_at_kaaba"
                android:textColor="@color/green_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/align_prayer_mat"
                android:textColor="@color/text_3"
                android:textSize="11sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_direction"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/save_direction"
            android:textSize="12sp"
            style="@style/Widget.QiblaAR.Button"
            app:icon="@drawable/ic_lock"
            app:iconSize="14dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </LinearLayout>

    <!-- ── Locked bottom bar (shown when LOCKED) ── -->
    <LinearLayout
        android:id="@+id/ll_locked_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="90dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/bg_card_green"
        android:visibility="gone">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_lock"
            android:tint="@color/green"
            android:importantForAccessibility="no" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pre-set direction · gyro lock"
                android:textColor="@color/green_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_locked_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_3"
                android:textSize="11sp"
                android:text="Won't drift from metal here" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unlock_ar"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Unlock"
            android:textSize="12sp"
            style="@style/Widget.QiblaAR.Button.Quiet"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </LinearLayout>

    <!-- ── Searching footer text ── -->
    <TextView
        android:id="@+id/tv_searching_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="104dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="@color/text_3"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/bg_chip_neutral"
        android:text="@string/sweep_right"
        android:visibility="gone" />

</FrameLayout>
