<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Eyebrow row: step label + accuracy chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/calibration_step_header"
                android:textColor="@color/text_4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tv_accuracy_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="@string/needs_calibration"
                android:textColor="@color/amber_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_card_amber" />

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calibration_title"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:gravity="center"
            android:layout_marginBottom="10dp" />

        <!-- Body -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/calibration_instructions"
            android:textColor="@color/text_2"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.55"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <!-- Figure-8 illustration (static icon, full size) -->
        <ImageView
            android:id="@+id/iv_figure8"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/ic_figure8"
            android:contentDescription="Figure-8 motion diagram"
            android:layout_marginBottom="28dp" />

        <!-- Progress label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_progress_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/calibration_progress_label"
                android:textColor="@color/text_2"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_accuracy_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/amber"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progress_calibration"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:progressDrawable="@drawable/bg_progress_bar"
            android:max="100"
            android:progress="15"
            android:layout_marginBottom="28dp" />

        <!-- Done button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_done"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="@string/done"
            style="@style/Widget.QiblaAR.Button"
            android:enabled="false"
            android:layout_marginBottom="20dp" />

        <!-- Tips card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_card_neutral">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/calibration_tip_title"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Tip 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_magnet"
                    android:tint="@color/text_3"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/calibration_tip_metal"
                    android:textColor="@color/text_2"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <!-- Tip 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_rotate_ccw"
                    android:tint="@color/text_3"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/calibration_tip_twist"
                    android:textColor="@color/text_2"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <!-- Tip 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_rotate_ccw"
                    android:tint="@color/text_3"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/calibration_tip_repeat"
                    android:textColor="@color/text_2"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
